    <string name="accessibility_required_title">Servicio de accesibilidad requerido</string>
    <string name="accessibility_required_description">Activa el servicio de accesibilidad para que la app detecte la aplicación en primer plano y muestre el overlay de navegación en las apps seleccionadas.</string>
    <string name="open_accessibility_settings">Abrir ajustes de accesibilidad</string>
