    <string name="help_sub_select">Selecionar botão</string>
    <string name="help_body_apps">A lista mostra todos os apps instalados no seu dispositivo. Ative um app para que o overlay NavXS apareça quando estiver em primeiro plano. Use a barra de pesquisa para filtrar por nome, ou ative Mostrar apps do sistema.</string>
    <string name="help_body_position">Abre um editor em ecrã inteiro. Arraste qualquer botão ativo para exatamente onde deve aparecer no overlay. Toque num botão para selecioná-lo sem movê-lo. O ícone de repor restaura todas as posições predefinidas. O painel de precisão move o botão selecionado um passo exato em pixéis.</string>
    <string name="help_body_select">Toque em Voltar, Início ou Recentes para selecionar um botão. Todas as configurações abaixo aplicam-se apenas ao botão selecionado.</string>
    <string name="help_body_active">Ativa ou desativa o botão selecionado no overlay. Pelo menos um botão deve permanecer ativo em todos os momentos.</string>
    <string name="help_desc_theme">Escolhe o estilo do ícone.</string>
    <string name="help_desc_colour">Define a cor do ícone.</string>
    <string name="help_desc_opacity">Transparência do ícone — 0 invisível, 100 totalmente opaco.</string>
    <string name="help_desc_size">Dimensiona o ícone em relação ao seu tamanho predefinido.</string>
    <string name="help_button_bg_intro">Um círculo opcional desenhado atrás do ícone para melhorar a visibilidade em qualquer fundo.</string>
    <string name="help_desc_bg_colour">Cor de preenchimento do círculo de fundo.</string>
    <string name="help_desc_bg_opacity">Transparência do círculo de fundo.</string>
    <string name="help_desc_bg_size">Diâmetro do círculo relativo ao ícone.</string>
    <string name="help_desc_bg_softness">0 = borda nítida; 100 = borda totalmente desbotada.</string>
    <string name="help_body_preview">A pequena aba no canto superior direito do ecrã de configurações abre um painel com o botão selecionado sobre fundos branco, cinzento e preto — avalie a visibilidade em qualquer app sem sair das configurações.</string>
