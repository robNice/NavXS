    <string name="disclosure_title">Accessibility Service</string>
    <string name="disclosure_item_1">NavXS uses the Android Accessibility Service.</string>
    <string name="disclosure_item_2">The service is required to display floating navigation buttons over selected apps.</string>
    <string name="disclosure_item_3">NavXS can detect which app is currently in the foreground.</string>
    <string name="disclosure_item_4">NavXS uses Accessibility actions: Back, Home and Recent Apps.</string>
    <string name="disclosure_item_5">NavXS does not read typed text, passwords or message content.</string>
    <string name="disclosure_item_6">NavXS does not sell or share this data.</string>
    <string name="disclosure_item_7">Processing is performed solely to provide the navigation overlay feature.</string>
    <string name="disclosure_checkbox">I understand why NavXS needs the Accessibility Service.</string>
